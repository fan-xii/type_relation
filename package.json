{
  "name": "roco-type-checker",
  "version": "1.0.0",
  "description": "洛克王国世界 - 属性克制查询工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.roco.type-checker",
    "productName": "洛克王国属性克制查询",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/app_icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "洛克王国属性克制查询"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "^26.8.1"
  }
}
